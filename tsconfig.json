{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "lib": ["esnext"],
    "types": ["node"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "ignoreDeprecations": "6.0",
    "paths": {
      "@/*": ["./src/*"],
      "prisma-client-custom": ["./generated/prisma/client.js"]
    }
  },
  "include": ["src/**/*"], // 🎯 ফিক্সড: এখানে শুধু আপনার সোর্স কোড থাকবে
  "exclude": [
    "node_modules", 
    "generated/prisma/**/*", // 🎯 ফিক্সড: প্রিজমার জেনারেটেড ফাইল বিল্ড প্রসেস থেকে বাদ দেওয়া হলো
    "dist"
  ]
}